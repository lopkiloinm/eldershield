# ─── Ghost-managed Postgres ───────────────────────────────────────────────────
# Get this from your Ghost.build project dashboard
DATABASE_URL=postgresql://user:password@host:5432/eldershield

# ─── Redis ────────────────────────────────────────────────────────────────────
# Either set REDIS_URL (takes precedence) or REDIS_HOST + REDIS_PORT
REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ─── TinyFish Web Agent ───────────────────────────────────────────────────────
TINYFISH_API_KEY=your_tinyfish_api_key_here

# ─── Nexla – Slack inbox ingestion ───────────────────────────────────────────
# Session token: copy from https://dataops.nexla.io/nexla-api
#   Settings → Authentication → copy the token shown on the page.
#   Expires ~1h — fine for hackathon demo. Use a service key for prod.
NEXLA_API_URL=https://dataops.nexla.io/nexla-api
NEXLA_SESSION_TOKEN=paste-your-session-token-here

# Nexset ID: create a Slack "Fetch Channel Messages (Incremental)" flow in Nexla UI,
# then copy the resulting Nexset ID here.
NEXLA_INBOX_NEXSET_ID=12345

# The Slack channel ID you connected (e.g. C0123456789) — used for logging only
NEXLA_SLACK_CHANNEL_ID=C0123456789

# ─── GitHub (for cited.md publishing) ────────────────────────────────────────
GITHUB_OWNER=your-github-username
GITHUB_REPO=eldershield
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_CITED_PATH=cited.md
GITHUB_BRANCH=main

# ─── x402 Payment Rails ───────────────────────────────────────────────────────
# Set to "demo-token" to accept any non-empty token (hackathon mode)
# Set to a real secret to enforce strict token matching
PAYMENT_TOKEN_SECRET=demo-token

# ─── Redis Agent Memory Server ───────────────────────────────────────────────
# Run locally:
#   docker run -d --name agent-memory \
#     -e OPENAI_API_KEY=$OPENAI_API_KEY \
#     -e REDIS_URL=$REDIS_URL \
#     -p 8000:8000 \
#     redis/agent-memory-server:latest
#
# Set DISABLE_AUTH=true on the server for local dev (no token needed).
AGENT_MEMORY_URL=http://localhost:8000
AGENT_MEMORY_TOKEN=

# ─── Senso context layer ──────────────────────────────────────────────────────
# Makes cited.md discoverable + monetizable by AI agents
# Sign up at senso.ai, get API key
SENSO_API_KEY=
SENSO_API_BASE=https://api.senso.ai
SENSO_CITED_MD_URL=https://raw.githubusercontent.com/lopkiloinm/eldershield/main/cited.md

# ─── Vapi voice AI ────────────────────────────────────────────────────────────
# Sign up at vapi.ai, create an assistant, set webhook to PUBLIC_URL/api/vapi/tool-call
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
# Public URL for Vapi webhooks (use ngrok for local dev: ngrok http 3000)
PUBLIC_URL=http://localhost:3000

# ─── Autonomous worker ────────────────────────────────────────────────────────
# Set to true to enable the built-in worker loop (polls queue every WORKER_POLL_MS ms)
AUTONOMOUS_MODE=true
WORKER_POLL_MS=15000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
