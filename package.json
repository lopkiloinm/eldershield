{
  "name": "eldershield",
  "version": "1.0.0",
  "description": "Autonomous scam-protection agent for older adults",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "psql $DATABASE_URL -f schema.sql"
  },
  "dependencies": {
    "bullmq": "5.7.0",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "ioredis": "5.3.2",
    "pg": "8.11.5",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.12.12",
    "@types/pg": "8.11.6",
    "@types/uuid": "9.0.8",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
